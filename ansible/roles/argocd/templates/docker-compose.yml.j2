services:
  k3s:
    image: rancher/k3s:latest
    container_name: k3s
    command: ["server", "--disable=traefik"]
    privileged: true
    environment:
      - K3S_KUBECONFIG_OUTPUT=/output/kubeconfig.yaml
    volumes:
      - k3s_data:/var/lib/rancher/k3s
      - k3s_config:/output
    networks:
      - devops-network

  argocd:
    image: quay.io/argoproj/argocd:latest
    container_name: argocd
    command: ["argocd-server", "--insecure"]
    ports:
      - "{{ argocd_port }}:8080"
    environment:
      - KUBERNETES_MASTER=https://k3s:6443
      - ARGOCD_SERVER_INSECURE=true
    volumes:
      - k3s_config:/etc/kubernetes:ro
    depends_on:
      - k3s
    networks:
      - devops-network

  redis:
    image: redis:alpine
    container_name: argocd-redis
    networks:
      - devops-network
    restart: unless-stopped

volumes:
  k3s_data:
  k3s_config:
  argocd_data:

networks:
  devops-network:
    external: true
